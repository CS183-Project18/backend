<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.storefinds.uniquefindsbackend.mapper.PostFavoriteMapper">

    <resultMap id="FavoritePostResultMap" type="com.storefinds.uniquefindsbackend.entity.Post">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="storeId" column="store_id"/>
        <result property="categoryId" column="category_id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="priceMin" column="price_min"/>
        <result property="priceMax" column="price_max"/>
        <result property="currency" column="currency"/>
        <result property="locationText" column="location_text"/>
        <result property="status" column="status"/>
        <result property="moderationReason" column="moderation_reason"/>
        <result property="viewCount" column="view_count"/>
        <result property="likeCount" column="like_count"/>
        <result property="favoriteCount" column="favorite_count"/>
        <result property="commentCount" column="comment_count"/>
        <result property="publishedAt" column="published_at"/>
        <result property="deletedAt" column="deleted_at"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="authorUsername" column="author_username"/>
    </resultMap>

    <sql id="FavoritePostSelectColumns">
        p.id, p.user_id, p.store_id, p.category_id, p.title, p.description,
        p.price_min, p.price_max, p.currency, p.location_text, p.status,
        p.moderation_reason, p.view_count, p.like_count, p.favorite_count,
        p.comment_count, p.published_at, p.deleted_at, p.created_at, p.updated_at,
        u.username AS author_username
    </sql>

    <insert id="insertIgnore">
        INSERT IGNORE INTO post_favorites (user_id, post_id)
        VALUES (#{userId}, #{postId})
    </insert>

    <delete id="deleteByUserIdAndPostId">
        DELETE FROM post_favorites
        WHERE user_id = #{userId}
          AND post_id = #{postId}
    </delete>

    <select id="countByUserIdAndPostId" resultType="int">
        SELECT COUNT(1)
        FROM post_favorites
        WHERE user_id = #{userId}
          AND post_id = #{postId}
    </select>

    <select id="selectFavoritedPostIds" resultType="long">
        SELECT post_id
        FROM post_favorites
        WHERE user_id = #{userId}
          AND post_id IN
        <foreach collection="postIds" item="postId" open="(" separator="," close=")">
            #{postId}
        </foreach>
    </select>

    <select id="selectFavoritePostsByUserId" resultMap="FavoritePostResultMap">
        SELECT
        <include refid="FavoritePostSelectColumns"/>
        FROM post_favorites pf
        INNER JOIN posts p ON p.id = pf.post_id
        INNER JOIN users u ON u.id = p.user_id
        WHERE pf.user_id = #{userId}
          AND p.status = 'PUBLISHED'
        ORDER BY pf.created_at DESC, p.id DESC
    </select>

</mapper>
